```html
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>航海避碰教學互動平台</title>
    <style>
        body { font-family: sans-serif; margin: 0; background: #eef2f3; touch-action: none; }
        nav { background: #004e70; padding: 15px; display: flex; justify-content: space-around; }
        nav a { color: white; cursor: pointer; font-weight: bold; text-decoration: none; }
        .content { padding: 20px; display: none; }
        .active { display: block; }
        .card { background: white; padding: 20px; border-radius: 10px; margin-bottom: 20px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .btn { padding: 12px 24px; background: #007bff; color: white; border: none; cursor: pointer; border-radius: 5px; margin: 5px; font-size: 16px; }
        
        /* 遊戲區域放大調整 */
        #game-area { position: relative; width: 90vw; height: 70vh; background: #4facfe; margin: 0 auto; overflow: hidden; border: 4px solid #fff; }
        .unit { position: absolute; width: 9vw; height: 7vh; display: flex; justify-content: center; align-items: center; font-size: 40px; transition: all 0.1s; }
        #overlay { position: absolute; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.8); color: white; display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 50; }
    </style>
</head>
<body>

<nav>
    <a onclick="showTab('rules')">避碰規則</a>
    <a onclick="showTab('lights')">燈號學習</a>
    <a onclick="showTab('quiz')">測驗評量</a>
    <a onclick="showTab('game')">避讓遊戲</a>
</nav>

<div id="rules" class="content active">
    <div class="card">
        <h2>國際海上避碰規則重點</h2>
        <ul>
            <li>對遇局面：兩動力船航向相反，均應向右轉，以左舷通過。</li>
            <li>交叉相遇：見他船在右舷者為讓路船，應避讓。</li>
            <li>追越：被追越船為直航船，須保持航向與速度。</li>
        </ul>
    </div>
</div>

<div id="lights" class="content">
    <div class="card">
        <h2>船舶燈號識別</h2>
        <p>🔴紅燈：左舷 | 🟢綠燈：右舷</p>
        <p>🔴🔴失控船 | 🟡🟡拖船</p>
    </div>
</div>

<div id="quiz" class="content">
    <div class="card" id="quiz-box">
        <h2 id="q-text">測驗開始</h2>
        <div id="q-opts"></div>
        <div id="feedback" style="font-weight:bold; margin-top:10px;"></div>
        <p>目前得分：<span id="score">0</span> / 10</p>
    </div>
</div>

<div id="game" class="content">
    <div class="card">
        <h3>遊戲生命值: <span id="life">5</span></h3>
        <div id="game-area">
            <div id="overlay">
                <button onclick="startGame()" style="padding:20px; font-size:24px;">點擊開始遊戲</button>
            </div>
            <div id="ship" class="unit">🚢</div>
            <div id="o1" class="unit">🛢️</div>
            <div id="o2" class="unit">🛳️</div>
            <div id="o3" class="unit">🎣</div>
        </div>
    </div>
</div>

<script>
    let life = 5, score = 0, currentQ = 0, gameStarted = false;
    let shipPos = { x: 4, y: 8 };
    const obstacles = [
        { el: document.getElementById('o1'), x: 0, y: 0, speed: 1000, type: 'chase' },
        { el: document.getElementById('o2'), x: 9, y: 0, speed: 800, type: 'wander' },
        { el: document.getElementById('o3'), x: 9, y: 9, speed: 1200, type: 'random' }
    ];

    function showTab(id) {
        document.querySelectorAll('.content').forEach(c => c.classList.remove('active'));
        document.getElementById(id).classList.add('active');
    }

    // 測驗邏輯
    const questions = [
        { q: "對遇局面應如何避讓？", a: ["各自向右轉", "各自向左轉"], correct: 0 },
        { q: "交叉相遇時，右舷有他船為？", a: ["讓路船", "直航船"], correct: 0 },
        { q: "被追越船為？", a: ["讓路船", "直航船"], correct: 1 },
        { q: "垂直兩紅燈代表？", a: ["失控船", "拖船"], correct: 0 },
        { q: "動力船是否應保持安全速度？", a: ["是", "否"], correct: 0 },
        { q: "追越他船應避讓嗎？", a: ["是", "否"], correct: 0 },
        { q: "垂直兩黃燈代表？", a: ["拖船", "捕魚船"], correct: 0 },
        { q: "在霧中能適用互見規則嗎？", a: ["不能", "能"], correct: 0 },
        { q: "航行時是否需保持瞭望？", a: ["是", "否"], correct: 0 },
        { q: "交叉相遇時，應盡量避免？", a: ["橫越船首", "轉向"], correct: 0 }
    ];

    function loadQuiz() {
        if(currentQ >= questions.length) { document.getElementById('quiz-box').innerHTML = `<h3>測驗結束！總分：${score}</h3>`; return; }
        document.getElementById('q-text').innerText = questions[currentQ].q;
        let html = "";
        questions[currentQ].a.forEach((opt, i) => html += `<button class="btn" onclick="check(${i})">${opt}</button>`);
        document.getElementById('q-opts').innerHTML = html;
    }

    function check(idx) {
        if(idx === questions[currentQ].correct) { score++; life++; document.getElementById('life').innerText = life; document.getElementById('feedback').innerText = "答對！生命值+1"; document.getElementById('feedback').style.color="green"; }
        else { document.getElementById('feedback').innerText = "答錯了"; document.getElementById('feedback').style.color="red"; }
        document.getElementById('score').innerText = score;
        currentQ++; setTimeout(loadQuiz, 1000);
    }

    // 遊戲邏輯
    function update() {
        document.getElementById('ship').style.left = (shipPos.x * 9) + 'vw';
        document.getElementById('ship').style.top = (shipPos.y * 7) + 'vh';
        obstacles.forEach(o => {
            o.el.style.left = (o.x * 9) + 'vw';
            o.el.style.top = (o.y * 7) + 'vh';
        });
    }

    function startGame() { gameStarted = true; document.getElementById('overlay').style.display = 'none'; update(); }

    // 優化後的移動邏輯
    document.addEventListener('keydown', e => {
        if(!gameStarted) return;
        if(e.key === 'ArrowLeft') shipPos.x = Math.max(0, shipPos.x - 1);
        if(e.key === 'ArrowRight') shipPos.x = Math.min(9, shipPos.x + 1);
        if(e.key === 'ArrowUp') shipPos.y = Math.max(0, shipPos.y - 1);
        if(e.key === 'ArrowDown') shipPos.y = Math.min(9, shipPos.y + 1);
        update();
    });

    let startX, startY;
    document.getElementById('game-area').addEventListener('touchstart', e => { startX = e.touches[0].clientX; startY = e.touches[0].clientY; });
    document.getElementById('game-area').addEventListener('touchend', e => {
        if(!gameStarted) return;
        let dx = e.changedTouches[0].clientX - startX;
        let dy = e.changedTouches[0].clientY - startY;
        if(Math.abs(dx) > Math.abs(dy)) shipPos.x = Math.max(0, Math.min(9, shipPos.x + (dx > 0 ? 1 : -1)));
        else shipPos.y = Math.max(0, Math.min(9, shipPos.y + (dy > 0 ? 1 : -1)));
        update();
    });

    obstacles.forEach(o => {
        setInterval(() => {
            if(!gameStarted || life <= 0) return;
            if (o.type === 'chase') { o.x += (o.x < shipPos.x ? 1 : o.x > shipPos.x ? -1 : 0); o.y += (o.y < shipPos.y ? 1 : o.y > shipPos.y ? -1 : 0); }
            else if (o.type === 'wander') { o.x = Math.max(0, Math.min(9, o.x + (Math.random() > 0.5 ? 1 : -1))); o.y = Math.max(0, Math.min(9, o.y + (Math.random() > 0.5 ? 1 : -1))); }
            else { o.x = Math.floor(Math.random() * 10); o.y = Math.floor(Math.random() * 10); }
            if (o.x === shipPos.x && o.y === shipPos.y) { life--; document.getElementById('life').innerText = life; if (life <= 0) { gameStarted = false; document.getElementById('overlay').style.display = 'flex'; } }
            update();
        }, o.speed);
    });

    loadQuiz();
</script>
</body>
</html>

